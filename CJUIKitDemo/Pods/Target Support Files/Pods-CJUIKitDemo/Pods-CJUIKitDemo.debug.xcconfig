ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace" "${PODS_CONFIGURATION_BUILD_DIR}/YYText"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper/CJBaseHelper.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift/CJDataVientianeSDK_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation/CJFoundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager/IQKeyboardManager.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace/UINavigation_SXFixSpace.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/YYText/YYText.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper/CJBaseHelper.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift/CJDataVientianeSDK_Swift.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation/CJFoundation.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager/IQKeyboardManager.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace/UINavigation_SXFixSpace.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/YYText/YYText.framework/Headers" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/YYText"
OTHER_LDFLAGS = $(inherited) -framework "Accelerate" -framework "CJBaseHelper" -framework "CJBaseUIKit" -framework "CJDataVientianeSDK_Swift" -framework "CJFoundation" -framework "CQDemoKit" -framework "CoreFoundation" -framework "CoreGraphics" -framework "CoreText" -framework "Foundation" -framework "IQKeyboardManager" -framework "Masonry" -framework "MobileCoreServices" -framework "QuartzCore" -framework "UIKit" -framework "UINavigation_SXFixSpace" -framework "YYText"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "-F${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "-F${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace" "-F${PODS_CONFIGURATION_BUILD_DIR}/YYText"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
