ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift/CJDataVientianeSDK_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK/CJDataVientianeSDK.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource/CQDemoResource.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager/IQKeyboardManager.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane-Swift/TSDemo_DataVientiane_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane/TSDemo_DataVientiane.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace/UINavigation_SXFixSpace.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK/CJDataVientianeSDK.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift/CJDataVientianeSDK_Swift.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource/CQDemoResource.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager/IQKeyboardManager.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane/TSDemo_DataVientiane.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane-Swift/TSDemo_DataVientiane_Swift.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace/UINavigation_SXFixSpace.framework/Headers" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane-Swift" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace"
OTHER_LDFLAGS = $(inherited) -framework "CJBaseUIKit" -framework "CJDataVientianeSDK" -framework "CJDataVientianeSDK_Swift" -framework "CQDemoKit" -framework "CQDemoResource" -framework "CoreGraphics" -framework "Foundation" -framework "IQKeyboardManager" -framework "Masonry" -framework "QuartzCore" -framework "TSDemo_DataVientiane" -framework "TSDemo_DataVientiane_Swift" -framework "UIKit" -framework "UINavigation_SXFixSpace"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "-F${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "-F${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_DataVientiane-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
